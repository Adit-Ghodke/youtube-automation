# API Keys - Replace with your actual secret keys

# Get your FREE Groq API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Get your Pexels API key from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# Path to YouTube credentials file
YOUTUBE_CREDENTIALS_PATH=./youtube_credentials.json

# Email Alert Settings (Optional)
# If filled, you will receive email alerts on critical failures
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ALERT_EMAIL=your-email@gmail.com
ALERT_PASSWORD=your-app-specific-password
ALERT_RECIPIENT=your-recipient@gmail.com
